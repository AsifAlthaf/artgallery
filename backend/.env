// backend/.env
NODE_ENV=development
PORT=5000

MONGO_URI=mongodb+srv://<username>:<password>@<your-cluster-url>/artbloom?retryWrites=true&w=majority
JWT_SECRET=a_very_secret_jwt_key_that_is_long_and_random
JWT_EXPIRE=30d # e.g., 30 days

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

STRIPE_SECRET_KEY=sk_test_****************************************
STRIPE_WEBHOOK_SECRET=whsec_**************************************** # Get this from Stripe dashboard

# For Email Service (Nodemailer with Gmail example)
EMAIL_SERVICE_HOST=smtp.gmail.com
EMAIL_SERVICE_PORT=587
EMAIL_SERVICE_USER=shinchan.nohara3006@gmail.com
EMAIL_SERVICE_PASS=your_email_app_password # IMPORTANT: Use an App Password for Gmail, not your regular password

# For Google OAuth (if implementing server-side Google OAuth, not just client-side Firebase)
# If you're solely using Firebase client-side for Google Auth, these might not be needed on the backend.
# But for server-side integration or refreshing tokens, they are.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback